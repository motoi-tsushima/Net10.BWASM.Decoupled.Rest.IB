@page "/issues/create"
@inject IssueApiService ApiService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>課題新規登録</PageTitle>

<h1>課題新規登録</h1>

@if (_errorMessage is not null)
{
    <p style="color: red;">@_errorMessage</p>
}

<EditForm Model="_model" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />

    <div style="margin-bottom: 0.5rem;">
        <label>記入者氏名 <span style="color: red;">*</span></label><br />
        <InputText @bind-Value="_model.AuthorName" style="width: 300px;" />
        <ValidationMessage For="() => _model.AuthorName" />
    </div>

    <div style="margin-bottom: 0.5rem;">
        <label>カテゴリ名</label><br />
        <InputText @bind-Value="_model.Category" style="width: 200px;" />
        <ValidationMessage For="() => _model.Category" />
    </div>

    <div style="margin-bottom: 0.5rem;">
        <label>課題タイトル <span style="color: red;">*</span></label><br />
        <InputText @bind-Value="_model.Title" style="width: 400px;" />
        <ValidationMessage For="() => _model.Title" />
    </div>

    <div style="margin-bottom: 0.5rem;">
        <label>課題の文面 <span style="color: red;">*</span></label><br />
        <InputTextArea @bind-Value="_model.Description" rows="6" style="width: 400px;" />
        <ValidationMessage For="() => _model.Description" />
    </div>

    <div style="margin-top: 1rem;">
        <button type="submit" disabled="@_submitting">登録</button>
        <button type="button" @onclick="GoToList">戻る</button>
    </div>
</EditForm>

@code {
    private readonly CreateIssueDto _model = new();
    private bool _submitting;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var savedName = await JS.InvokeAsync<string?>("localStorage.getItem", "authorName");
        if (!string.IsNullOrEmpty(savedName))
        {
            _model.AuthorName = savedName;
        }
    }

    private async Task HandleSubmit()
    {
        _submitting = true;
        _errorMessage = null;
        try
        {
            await ApiService.CreateAsync(_model);
            await JS.InvokeVoidAsync("localStorage.setItem", "authorName", _model.AuthorName);
            Nav.NavigateTo("/issues");
        }
        catch
        {
            _errorMessage = "登録に失敗しました。";
            _submitting = false;
        }
    }

    private void GoToList() => Nav.NavigateTo("/issues");
}

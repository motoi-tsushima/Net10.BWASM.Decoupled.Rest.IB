@page "/issues/{Id:int}"
@inject IssueApiService ApiService
@inject NavigationManager Nav

<PageTitle>課題内容表示</PageTitle>

<h1>課題内容表示</h1>

@if (_loading)
{
    <p>読み込み中...</p>
}
else if (_errorMessage is not null)
{
    <p style="color: red;">@_errorMessage</p>
}
else if (_issue is not null)
{
    <table border="1" style="border-collapse: collapse; min-width: 600px;">
        <tr>
            <th style="text-align: left; padding: 4px 8px; width: 150px;">記入者氏名</th>
            <td style="padding: 4px 8px;">@_issue.AuthorName</td>
        </tr>
        <tr>
            <th style="text-align: left; padding: 4px 8px;">登録日時</th>
            <td style="padding: 4px 8px;">@_issue.CreatedAt.ToString("yyyy/MM/dd HH:mm:ss")</td>
        </tr>
        <tr>
            <th style="text-align: left; padding: 4px 8px;">カテゴリ名</th>
            <td style="padding: 4px 8px;">@(_issue.Category ?? "-")</td>
        </tr>
        <tr>
            <th style="text-align: left; padding: 4px 8px;">課題タイトル</th>
            <td style="padding: 4px 8px;">@_issue.Title</td>
        </tr>
        <tr>
            <th style="text-align: left; padding: 4px 8px;">課題の文面</th>
            <td style="padding: 4px 8px; white-space: pre-wrap;">@_issue.Description</td>
        </tr>
        <tr>
            <th style="text-align: left; padding: 4px 8px;">現在の状況</th>
            <td style="padding: 4px 8px;">@IssueStatusHelper.GetDisplayName(_issue.Status)</td>
        </tr>
        <tr>
            <th style="text-align: left; padding: 4px 8px;">解決の文面</th>
            <td style="padding: 4px 8px; white-space: pre-wrap;">@_issue.Resolution</td>
        </tr>
        <tr>
            <th style="text-align: left; padding: 4px 8px;">解決担当者名</th>
            <td style="padding: 4px 8px;">@_issue.ResolverName</td>
        </tr>
        <tr>
            <th style="text-align: left; padding: 4px 8px;">最終結果日時</th>
            <td style="padding: 4px 8px;">@(_issue.ResolvedAt?.ToString("yyyy/MM/dd HH:mm:ss"))</td>
        </tr>
    </table>

    <div style="margin-top: 1rem;">
        <button @onclick="GoToEdit">編集</button>
        <button @onclick="GoToDelete">削除</button>
        <button @onclick="GoToList">戻る</button>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private IssueDto? _issue;
    private bool _loading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _issue = await ApiService.GetByIdAsync(Id);
            if (_issue is null) _errorMessage = "課題が見つかりません。";
        }
        catch
        {
            _errorMessage = "データの読み込みに失敗しました。";
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoToEdit() => Nav.NavigateTo($"/issues/{Id}/edit");
    private void GoToDelete() => Nav.NavigateTo($"/issues/{Id}/delete");
    private void GoToList() => Nav.NavigateTo("/issues");
}
